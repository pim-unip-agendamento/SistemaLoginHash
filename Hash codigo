using System;
using System.Collections.Generic;
using System.IO;
using System.Security.Cryptography;
using System.Text;
using System.Text.Json;

class Program
{
    static string caminhoArquivo = "usuarios.json";

    static List<Usuario> usuarios = new List<Usuario>();

    static void Main()
    {
        CarregarUsuarios();

        Console.WriteLine("=== CADASTRO DE USUÁRIO ===");

        Usuario usuario = new Usuario();

        Console.Write("Nome: ");
        usuario.Nome = Console.ReadLine();

        Console.Write("Email: ");
        usuario.Email = Console.ReadLine();

        Console.Write("Senha: ");
        string senha = Console.ReadLine();

        usuario.HashSenha = GerarHash(senha);

        usuarios.Add(usuario);

        SalvarUsuarios();

        Console.WriteLine("\nUsuário salvo com sucesso!");
    }

    static void SalvarUsuarios()
    {
        string json = JsonSerializer.Serialize(
            usuarios,
            new JsonSerializerOptions
            {
                WriteIndented = true
            }
        );

        File.WriteAllText(caminhoArquivo, json);
    }

    static void CarregarUsuarios()
    {
        if (File.Exists(caminhoArquivo))
        {
            string json = File.ReadAllText(caminhoArquivo);

            usuarios = JsonSerializer.Deserialize<List<Usuario>>(json);
        }
    }

    static string GerarHash(string texto)
    {
        using (SHA256 sha256 = SHA256.Create())
        {
            byte[] bytes = sha256.ComputeHash(
                Encoding.UTF8.GetBytes(texto)
            );

            StringBuilder builder = new StringBuilder();

            foreach (byte b in bytes)
            {
                builder.Append(b.ToString("x2"));
            }

            return builder.ToString();
        }
    }
}
